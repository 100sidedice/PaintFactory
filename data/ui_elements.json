{
    "screen":{
        "data":{"__visible":true},
        "container":{"pos":[0,0], "size":[1920,1080], "keywords":["static", "globalParent"], "opts":{}}
    },

    "screen.moneyDisplay":{
        "data":{"__visible":true},
        "container":{"pos":["__middle","__bottom"], "size":[200,28], "keywords":["crop"], "opts":{}},
        "text":{
            "bind":"__GAME_STATE.inventory.money",
            "editable":false,
            "fontSize":20,
            "padding":[8,4],
            "color":"$theme.text.color"
        }
    },

    "screen.testButton":{
        "data":{
            "__toggled":false,
            "__color":"#FF0000",
            "__visible":true
        },
        "container":{"pos":[0,0], "size":[50,50], "keywords":["crop", "input"], "opts":{}},
        "colorRect":{"pos":[0,0], "size":[50,50], "color":"__color"},
        "outline":{"width":3},

        "input":{
            "mouseup.left":{"duration":0, "emit":"button1-toggle", "scope":["screen.testButton"]}
        },

        "valueReader":{
            "__toggled":{"value":false, "condition":"==", "action":{"setValue":"__color", "value":"#330000"}},
            "__toggled-1":{"value":true, "condition":"==", "action":{"setValue":"__color", "value":"#FF0000"}}
        },
        "eventReader":{
            "button1-toggle":{"actions":[{"toggleValue":{"var":"__toggled"}}]}
        }
    },

    "screen.nameInput":{
        "data":{
            "__visible":true,
            "__text":"",
            "__editingText":false,
            "__outlineColor":"#1E1E1E"
        },
        "container":{"pos":[20,70], "size":[280,36], "keywords":["crop", "input"], "opts":{}},
        "colorRect":{"color":"#1E1E1E"},
        "outline":{"width":2, "color":"__outlineColor"},
        "text":{
            "bind":"__text",
            "editingFlag":"__editingText",
            "editable":true,
            "placeholder":"Type name...",
            "fontSize":20,
            "padding":[8,8],
            "color":"$theme.text.color",
            "placeholderColor":"$theme.text.placeholder_color",
            "caretColor":"$theme.caret.color",
            "caretBlinkRate":"$theme.caret.blink_rate",
            "maxLength":24,
            "blurOnEnter":true
        },
        "valueReader":{
            "__editingText":{"value":true, "condition":"==", "action":{"setValue":"__outlineColor", "value":"$theme.focus.outline_color"}},
            "__editingText-1":{"value":false, "condition":"==", "action":{"setValue":"__outlineColor", "value":"#1E1E1E"}}
        }
    },


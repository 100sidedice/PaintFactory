            "size":[240,140],
            "keywords":["grid", "stretch", "crop"],
            "opts":{"columns":3, "gap":[6,6], "padding":[6,6], "cellSize":[70,60]}
        },
        "colorRect":{"color":"#232323"},
        "outline":{"width":2, "color":"#3A3A3A"}
